---
import type { Entry } from '../lib/content';
import { withBase } from '../lib/paths';
import { collectionMeta } from '../lib/site';
import { formatDate, getEntryHref } from '../lib/content';
import TagList from './TagList.astro';

interface Props {
  entry: Entry;
}

const { entry } = Astro.props;
const meta = collectionMeta[entry.collection];
const coverSrc = entry.data.cover ? withBase(entry.data.cover) : undefined;
---

<article class="featured-card surface card-hover">
  <a class="featured-card__link" href={getEntryHref(entry)}>
    {coverSrc && (
      <div class="featured-card__cover">
        <img src={coverSrc} alt="" loading="lazy" />
      </div>
    )}

    <div class="featured-card__body">
      <p class="eyebrow">{meta.label}</p>
      <h3>{entry.data.title}</h3>
      <p class="featured-card__description">{entry.data.description}</p>

      <div class="featured-card__footer">
        <span class="muted">{formatDate(entry.data.pubDate)}</span>
        <TagList tags={entry.data.tags} collection={entry.collection} />
      </div>
    </div>
  </a>
</article>

<style>
  .featured-card {
    overflow: hidden;
  }

  .featured-card__link {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1.15fr);
    min-height: 22rem;
  }

  .featured-card__cover {
    position: relative;
    overflow: hidden;
    min-height: 100%;
  }

  .featured-card__cover img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .featured-card__body {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 1.2rem;
    padding: clamp(1.6rem, 4vw, 2.4rem);
  }

  .featured-card h3 {
    margin: 0;
    font-family: var(--font-sans-en-display);
    font-size: clamp(2rem, 4vw, 3rem);
    line-height: 1;
    letter-spacing: -0.04em;
  }

  .featured-card__description {
    margin: 0;
    color: var(--text-secondary);
    font-size: 1.05rem;
  }

  .featured-card__footer {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  @media (max-width: 860px) {
    .featured-card__link {
      grid-template-columns: 1fr;
    }

    .featured-card__cover {
      min-height: 16rem;
    }
  }
</style>
