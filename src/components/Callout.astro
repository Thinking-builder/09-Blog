---
interface Props {
  title?: string;
}

const { title = 'Callout' } = Astro.props;
---

<aside class="callout">
  <strong>{title}</strong>
  <div class="callout__body">
    <slot />
  </div>
</aside>

<style>
  .callout {
    margin: 2rem 0;
    border: 1px solid rgba(124, 155, 255, 0.24);
    border-radius: var(--radius-md);
    padding: 1rem 1.1rem;
    background: rgba(124, 155, 255, 0.06);
  }

  .callout strong {
    display: block;
    margin-bottom: 0.5rem;
    font-family: var(--font-sans-en-display);
  }

  .callout__body :global(*:first-child) {
    margin-top: 0;
  }

  .callout__body :global(*:last-child) {
    margin-bottom: 0;
  }
</style>
