---
import { withBase } from '../lib/paths';

interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
  actionHref?: string;
  actionLabel?: string;
}

const { eyebrow, title, description, actionHref, actionLabel } = Astro.props;
const resolvedActionHref = actionHref ? withBase(actionHref) : undefined;
---

<div class="section-title">
  <div>
    {eyebrow && <p class="eyebrow">{eyebrow}</p>}
    <h2>{title}</h2>
    {description && <p class="lede">{description}</p>}
  </div>

  {resolvedActionHref && actionLabel && (
    <a class="button is-ghost" href={resolvedActionHref}>
      {actionLabel}
    </a>
  )}
</div>

<style>
  .section-title {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 1.5rem;
    margin-bottom: 1.75rem;
  }

  .section-title h2 {
    margin: 0;
    font-family: var(--font-sans-en-display);
    font-size: clamp(1.8rem, 3vw, 2.5rem);
    letter-spacing: -0.04em;
  }

  .section-title .lede {
    margin: 0.7rem 0 0;
    max-width: 38rem;
  }

  @media (max-width: 720px) {
    .section-title {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
