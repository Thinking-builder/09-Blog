---
import { homeHeroVideoConfig, getHomeHeroVideoCssVars } from '../lib/homeHeroVideo';
import { withBase } from '../lib/paths';
import { siteConfig } from '../lib/site';

const rootStyle = Object.entries(getHomeHeroVideoCssVars(homeHeroVideoConfig))
  .map(([key, value]) => `${key}:${value}`)
  .join(';');
const homeHref = withBase('/');
const navItems = siteConfig.nav.map((item) => ({
  ...item,
  href: withBase(item.href),
}));
const videoSrc = withBase(homeHeroVideoConfig.videoSrc);
const posterStyle = [
  `background-image:-webkit-image-set(url('${withBase(homeHeroVideoConfig.posterSrc)}') type('image/avif') 1x, url('${withBase(homeHeroVideoConfig.posterFallbackSrc)}') type('image/jpeg') 1x)`,
  `background-image:image-set(url('${withBase(homeHeroVideoConfig.posterSrc)}') type('image/avif') 1x, url('${withBase(homeHeroVideoConfig.posterFallbackSrc)}') type('image/jpeg') 1x)`,
].join(';');
---

<section class="sea-home" aria-label="首页" data-home-video-hero style={rootStyle}>
  <div class="sea-home__media" aria-hidden="true">
    <div class="sea-home__poster" style={posterStyle}></div>

    <video
      class="sea-home__video"
      autoplay
      muted
      loop
      playsinline
      preload="metadata"
      disablepictureinpicture
      aria-hidden="true"
    >
      <source src={videoSrc} type="video/mp4" />
    </video>

    <div class="sea-home__clarity-mask"></div>
    <div class="sea-home__veil"></div>
    <div class="sea-home__vignette"></div>
  </div>

  <div class="sea-home__overlay">
    <a class="sea-home__brand" href={homeHref} aria-label={siteConfig.title}>
      <span class="sea-home__brand-zh">{siteConfig.title}</span>
      <span class="sea-home__brand-en">{siteConfig.titleEn}</span>
    </a>

    <nav class="sea-home__nav" aria-label="Main navigation">
      {
        navItems.map((item) => (
          <a class="sea-home__nav-link" href={item.href}>
            <span class="sea-home__nav-zh">{item.labelZh}</span>
            <span class="sea-home__nav-en">{item.labelEn}</span>
          </a>
        ))
      }
    </nav>
  </div>
</section>

<script>
  const root = document.querySelector('[data-home-video-hero]');
  const video = root?.querySelector('video');
  const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)');

  if (root instanceof HTMLElement && video instanceof HTMLVideoElement) {
    const setReady = () => {
      root.dataset.videoReady = 'true';
    };

    const disableMotion = () => {
      root.dataset.reducedMotion = 'true';
      video.pause();
      video.currentTime = 0;
    };

    const enableMotion = async () => {
      root.dataset.reducedMotion = 'false';
      try {
        await video.play();
        setReady();
      } catch {
        root.dataset.videoReady = 'false';
      }
    };

    video.addEventListener('loadeddata', setReady, { once: true });
    video.addEventListener('canplay', setReady, { once: true });

    if (reduceMotion.matches) {
      disableMotion();
    } else {
      enableMotion();
    }

    reduceMotion.addEventListener('change', (event) => {
      if (event.matches) {
        disableMotion();
        return;
      }

      enableMotion();
    });
  }
</script>

<style>
  .sea-home {
    position: relative;
    min-height: 100svh;
    overflow: clip;
    isolation: isolate;
    background: #030a13;
  }

  .sea-home__media,
  .sea-home__poster,
  .sea-home__video,
  .sea-home__clarity-mask,
  .sea-home__veil,
  .sea-home__vignette,
  .sea-home__overlay {
    position: absolute;
    inset: 0;
  }

  .sea-home__poster,
  .sea-home__video,
  .sea-home__clarity-mask,
  .sea-home__veil,
  .sea-home__vignette {
    pointer-events: none;
  }

  .sea-home__poster {
    background-color: #04101a;
    background-position: var(--hero-object-position-desktop);
    background-size: cover;
    background-repeat: no-repeat;
    filter: brightness(0.95) contrast(1.04) saturate(0.96);
  }

  .sea-home__video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: var(--hero-object-position-desktop);
    opacity: 0;
    filter: brightness(0.94) contrast(1.04) saturate(0.96);
    transform: scale(var(--hero-video-scale));
    transform-origin: center center;
    transition: opacity 420ms ease;
    will-change: opacity;
  }

  .sea-home[data-video-ready='true'][data-reduced-motion='false'] .sea-home__video {
    opacity: 1;
  }

  .sea-home__clarity-mask {
    background:
      radial-gradient(
        circle at var(--hero-moon-focus-x) var(--hero-moon-focus-y),
        rgba(255, 246, 224, 0.06) 0%,
        rgba(255, 236, 202, 0.04) 7%,
        rgba(3, 10, 18, 0) 14%
      ),
      radial-gradient(
        circle at var(--hero-moon-focus-x) var(--hero-moon-focus-y),
        rgba(3, 10, 18, 0) 0%,
        rgba(3, 10, 18, 0) 11%,
        rgba(3, 10, 18, 0.08) 20%,
        rgba(3, 10, 18, 0) 31%
      );
    mix-blend-mode: screen;
    opacity: 0.9;
  }

  .sea-home__veil {
    background:
      linear-gradient(
        180deg,
        rgba(1, 8, 15, calc(var(--hero-veil-strength) + 0.18)),
        rgba(1, 8, 15, calc(var(--hero-veil-strength) * 0.72 + 0.12)) 28%,
        rgba(1, 8, 15, 0.08) 48%,
        rgba(1, 8, 15, 0.16) 100%
      ),
      linear-gradient(
        90deg,
        rgba(1, 8, 15, calc(var(--hero-veil-strength) + 0.12)),
        rgba(1, 8, 15, 0.08) 16%,
        rgba(1, 8, 15, 0.03) 50%,
        rgba(1, 8, 15, 0.08) 84%,
        rgba(1, 8, 15, calc(var(--hero-veil-strength) + 0.12))
      );
  }

  .sea-home__vignette {
    box-shadow:
      inset 0 0 10rem rgba(1, 6, 12, 0.26),
      inset 0 0 18rem rgba(1, 6, 12, 0.1);
  }

  .sea-home__overlay {
    z-index: 1;
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1.5rem;
    padding: 1.45rem 1.55rem 1rem;
  }

  .sea-home__overlay::before {
    content: '';
    position: absolute;
    inset: 0 0 auto 0;
    height: min(20rem, 40vh);
    background: linear-gradient(180deg, rgba(1, 8, 15, 0.64), rgba(1, 8, 15, 0.24) 48%, transparent 100%);
    pointer-events: none;
    z-index: -1;
  }

  .sea-home__brand {
    display: inline-grid;
    gap: 0.14rem;
    align-content: start;
    color: rgba(247, 241, 231, 0.94);
    text-shadow: 0 0 18px rgba(2, 7, 14, 0.62);
  }

  .sea-home__brand-zh {
    font-family: var(--font-logo-zh);
    font-size: clamp(1.5rem, 2.2vw, 2rem);
    line-height: 0.92;
    letter-spacing: 0.02em;
  }

  .sea-home__brand-en {
    color: rgba(236, 225, 205, 0.72);
    font-family: var(--font-logo-en);
    font-size: clamp(0.88rem, 1.2vw, 1.02rem);
    line-height: 1;
  }

  .sea-home__nav {
    display: flex;
    flex-wrap: wrap;
    justify-content: flex-end;
    gap: 0.8rem 1.2rem;
    max-width: min(56vw, 34rem);
    padding-top: 0.2rem;
  }

  .sea-home__nav-link {
    display: inline-flex;
    align-items: baseline;
    gap: 0.38rem;
    padding-bottom: 0.22rem;
    border-bottom: 1px solid rgba(255, 229, 181, 0.14);
    color: rgba(244, 239, 230, 0.86);
    text-shadow: 0 0 16px rgba(1, 6, 13, 0.7);
    transition:
      color 180ms ease,
      border-color 180ms ease,
      opacity 180ms ease;
  }

  .sea-home__nav-link:hover {
    color: rgba(255, 248, 236, 0.98);
    border-color: rgba(255, 229, 181, 0.32);
  }

  .sea-home__nav-zh {
    font-family: var(--font-logo-zh);
    font-size: 1.12rem;
    line-height: 0.92;
  }

  .sea-home__nav-en {
    color: rgba(233, 218, 190, 0.78);
    font-family: var(--font-logo-en);
    font-size: 0.88rem;
    line-height: 1;
  }

  @media (min-aspect-ratio: 16 / 7) {
    .sea-home__video {
      transform: scale(1.04);
    }
  }

  @media (max-width: 780px) {
    .sea-home__poster {
      background-position: var(--hero-object-position-mobile);
    }

    .sea-home__video {
      object-position: var(--hero-object-position-mobile);
    }

    .sea-home__overlay {
      flex-direction: column;
      align-items: flex-start;
      justify-content: flex-start;
      gap: 1rem;
      padding: 1.2rem 1rem 0.6rem;
    }

    .sea-home__nav {
      max-width: 100%;
      justify-content: flex-start;
      gap: 0.65rem 0.95rem;
    }
  }

  @media (max-width: 540px) {
    .sea-home__brand-zh {
      font-size: 1.34rem;
    }

    .sea-home__brand-en {
      font-size: 0.82rem;
    }

    .sea-home__nav {
      display: grid;
      gap: 0.48rem;
    }

    .sea-home__nav-link {
      justify-self: start;
    }

    .sea-home__overlay::before {
      height: min(17rem, 34vh);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .sea-home__video {
      display: none;
    }
  }
</style>
