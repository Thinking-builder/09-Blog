---
interface Props {
  source?: string;
}

const { source } = Astro.props;
---

<figure class="quote-block">
  <blockquote>
    <slot />
  </blockquote>
  {source && <figcaption>{source}</figcaption>}
</figure>

<style>
  .quote-block {
    margin: 2rem 0;
    padding: 1rem 0;
  }

  .quote-block blockquote {
    margin: 0;
    border-left: 0;
    padding: 0;
    color: var(--text-primary);
    font-size: 1.5rem;
    line-height: 1.5;
  }

  .quote-block figcaption {
    margin-top: 0.8rem;
    color: var(--text-secondary);
    font-size: 0.95rem;
  }
</style>
